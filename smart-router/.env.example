POSTGRES_USER=your_user_name
POSTGRES_PASSWORD=your_password
POSTGRES_DB=your_db_name
# App uses DB_PASSWORD (or set DATABASE_URL to skip separate vars)
DB_PASSWORD=your_password
DATABASE_URL=your_url_here

ANTHROPIC_API_KEY=your_key_here
OPENAI_API_KEY=your_key_here
CEREBRAS_API_KEY=your_key_here

# Optional: CORS allowlist (defaults to Streamlit app URL)
# DASHBOARD_URL=https://your-dashboard.streamlit.app

# API auth — set on Cloud Run and in Streamlit Cloud secrets (same value). Omit locally to disable auth.
API_KEY=your-long-random-string